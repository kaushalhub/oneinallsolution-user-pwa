# Same API host as user-app EXPO_PUBLIC_API_BASE_URL (no trailing slash)
VITE_API_BASE_URL=https://api.example.com

# Optional — same key can power: Maps Embed API (booking confirmation), Maps JavaScript API + Geocoding API
# (saved-address map pin + reverse geocode). Enable those APIs in Google Cloud for this key.
# VITE_GOOGLE_MAPS_API_KEY=

# Optional — Sentry browser DSN (production only). https://docs.sentry.io/platforms/javascript/guides/react/
# VITE_SENTRY_DSN=
